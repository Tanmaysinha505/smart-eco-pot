<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#161b22" android:gravity="center_vertical"
        android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:fontFamily="sans-serif-medium"
            android:text="🌿 EcoPot" android:textColor="#e6edf3" android:textSize="18sp" />
        <TextView android:id="@+id/connectionBadge" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="● Connecting"
            android:textColor="#8b949e" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:background="#161b22" android:orientation="horizontal">
        <TextView android:id="@+id/tabDashboard" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:background="#1c2128" android:fontFamily="sans-serif-medium"
            android:gravity="center" android:text="Dashboard"
            android:textColor="#3fb950" android:textSize="13sp" />
        <TextView android:id="@+id/tabBrowser" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:fontFamily="sans-serif-medium" android:gravity="center"
            android:text="Full View" android:textColor="#8b949e" android:textSize="13sp" />
    </LinearLayout>

    <TextView android:id="@+id/alertBanner" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:background="#f8514920"
        android:gravity="center" android:padding="8dp" android:text=""
        android:textColor="#f85149" android:textSize="12sp" android:visibility="gone" />

    <ScrollView android:id="@+id/nativeView" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:background="#0d1117" android:visibility="visible">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_marginEnd="8dp" android:layout_weight="1"
                    android:background="@drawable/card_dark" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/statOnlineVal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:fontFamily="sans-serif-medium"
                        android:text="0/2" android:textColor="#e6edf3" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Online" android:textColor="#8b949e" android:textSize="11sp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_marginEnd="8dp" android:layout_weight="1"
                    android:background="@drawable/card_dark" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/statAvgVal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:fontFamily="sans-serif-medium"
                        android:text="—" android:textColor="#e6edf3" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg Moisture" android:textColor="#8b949e" android:textSize="11sp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_weight="1" android:background="@drawable/card_dark"
                    android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/statWaterVal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:fontFamily="sans-serif-medium"
                        android:text="0" android:textColor="#e6edf3" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Waterings" android:textColor="#8b949e" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Plant 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp" android:background="@drawable/card_dark"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium" android:text="Plant 1"
                            android:textColor="#e6edf3" android:textSize="17sp" />
                        <TextView android:id="@+id/statusLabel1" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Waiting…"
                            android:textColor="#8b949e" android:textSize="12sp" />
                    </LinearLayout>
                    <TextView android:id="@+id/moistureValue1" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:fontFamily="sans-serif-medium"
                        android:text="--%"  android:textColor="#3fb950" android:textSize="30sp" />
                </LinearLayout>
                <ProgressBar android:id="@+id/moistureBar1"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent" android:layout_height="4dp"
                    android:layout_marginBottom="14dp" android:progressBackgroundTint="#30363d"
                    android:progressTint="#3fb950" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" android:orientation="horizontal">
                    <Button android:id="@+id/water1" android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_marginEnd="8dp" android:layout_weight="1"
                        android:background="@drawable/btn_blue" android:elevation="0dp"
                        android:stateListAnimator="@null" android:text="💧 Water"
                        android:textColor="#ffffff" android:textSize="13sp" />
                    <Button android:id="@+id/auto1" android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:background="@drawable/btn_auto_green"
                        android:elevation="0dp" android:stateListAnimator="@null"
                        android:text="⚡ Auto ON" android:textColor="#3fb950" android:textSize="13sp" />
                </LinearLayout>
                <TextView android:id="@+id/thrLabel1" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="6dp"
                    android:text="Threshold: 30% · Pump OFF at 60%"
                    android:textColor="#8b949e" android:textSize="11sp" />
                <SeekBar android:id="@+id/threshold1" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:max="80" android:progress="30"
                    android:progressTint="#d29922" android:thumbTint="#d29922" />
            </LinearLayout>

            <!-- Plant 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp" android:background="@drawable/card_dark"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium" android:text="Plant 2"
                            android:textColor="#e6edf3" android:textSize="17sp" />
                        <TextView android:id="@+id/statusLabel2" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Waiting…"
                            android:textColor="#8b949e" android:textSize="12sp" />
                    </LinearLayout>
                    <TextView android:id="@+id/moistureValue2" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:fontFamily="sans-serif-medium"
                        android:text="--%"  android:textColor="#3fb950" android:textSize="30sp" />
                </LinearLayout>
                <ProgressBar android:id="@+id/moistureBar2"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent" android:layout_height="6dp"
                    android:layout_marginBottom="14dp" android:progressBackgroundTint="#30363d"
                    android:progressTint="#3fb950" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" android:orientation="horizontal">
                    <Button android:id="@+id/water2" android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_marginEnd="8dp" android:layout_weight="1"
                        android:background="@drawable/btn_blue" android:elevation="0dp"
                        android:stateListAnimator="@null" android:text="💧 Water"
                        android:textColor="#ffffff" android:textSize="13sp" />
                    <Button android:id="@+id/auto2" android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:background="@drawable/btn_auto_green"
                        android:elevation="0dp" android:stateListAnimator="@null"
                        android:text="⚡ Auto ON" android:textColor="#3fb950" android:textSize="13sp" />
                </LinearLayout>
                <TextView android:id="@+id/thrLabel2" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="6dp"
                    android:text="Threshold: 30% · Pump OFF at 60%"
                    android:textColor="#8b949e" android:textSize="11sp" />
                <SeekBar android:id="@+id/threshold2" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:max="80" android:progress="30"
                    android:progressTint="#d29922" android:thumbTint="#d29922" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <WebView android:id="@+id/webView" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:visibility="gone" />

    <!-- Bottom Nav -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#161b22" android:elevation="8dp" android:orientation="horizontal">

        <LinearLayout android:id="@+id/navDashboard" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textColor="#3fb950" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navAnalytics" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📊" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Analytics" android:textColor="#8b949e" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navChatbot" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤖" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EcoBot" android:textColor="#8b949e" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navHistory" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💧" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textColor="#8b949e" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navSchedule" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Schedule" android:textColor="#8b949e" android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>